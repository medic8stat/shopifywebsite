    "section-rich-text-services": {
      "type": "section-rich-text",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "title": "Services We'll Offer",
            "heading_font_size": "heading-medium",
            "padding_bottom": 16,
            "heading_tag": "automatic"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>Our urgent care clinic will provide care for non-life-threatening conditions that need prompt attention:</p><ul><li>Minor injuries and cuts requiring stitches</li><li>Sprains and strains</li><li>Infections (ear, throat, urinary, skin)</li><li>Cold and flu symptoms. </li><li>Allergic reactions (non-severe)</li><li>Minor burns</li><li>Rashes and skin conditions</li><li>Eye infections and irritations</li><li>Stomach pain and digestive issues</li><li>Headaches and migraines</li></ul><p>For life-threatening emergencies, please call 911 or go to your nearest emergency department.</p>",
            "text_font_size": "body-medium",
            "padding_bottom": 24
          }
        }
      },
      "block_order": [
        "heading",
        "text"
