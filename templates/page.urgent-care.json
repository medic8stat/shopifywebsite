    "section-accordion": {
      "type": "section-accordion",
      "blocks": {
        "block": {
          "type": "text",
          "settings": {
            "title": "When will urgent care open?",
            "heading_font_size": "heading-small",
            "text": "<p>We open for same week appointments the 9th of June 2026! </p>"
          }
        },
        "block-0": {
          "type": "text",
          "settings": {
            "title": "Is urgent care covered by Medicare?",
            "heading_font_size": "heading-small",
            "text": "<p>Yes! For New Brunswick residents with valid Medicare coverage, urgent care physician services are covered at no cost. Some additional services or supplies may have fees. Our staff will inform you before providing any services with associated costs.</p>"
          }
        },
        "block-1": {
          "type": "text",
          "settings": {
            "title": "What should I bring to my visit?",
            "heading_font_size": "heading-small",
            "text": "<p>Please bring your NB Medicare card, a list of current medications, and any relevant medical information. If you don't have your Medicare card, we can still see you. We'll help you sort out billing afterward.</p>"
          }
        },
        "block-2": {
          "type": "text",
          "settings": {
            "title": "How long is the typical wait?",
            "heading_font_size": "heading-small",
            "text": "<p>Once you've contacted the clinic, you'll be sent some questionnaires to fill in online, then you will be booked based on clinical urgency. </p>"
          }
        },
        "block-3": {
          "type": "text",
          "settings": {
            "title": "Can out-of-province visitors use urgent care?",
            "heading_font_size": "heading-small",
            "text": "<p>Yes, we welcome patients from outside New Brunswick. You may need to pay at the time of service and submit a claim to your home province for reimbursement. We'll provide all necessary documentation.</p>"
          }
        }
      },
